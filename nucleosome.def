Bootstrap: docker
From: condaforge/mambaforge

%labels
    OWNER = Manish Yadav

%files
    /home/pol_schiessel/maya620d/pol/Projects/Codebase/Spermatogensis/environment.yml /environment.yml
    /home/pol_schiessel/maya620d/pol/Projects/Codebase/Spermatogensis/backend /opt/backend

%post
    /opt/conda/bin/mamba env create -f /environment.yml
    /opt/conda/bin/conda clean -afy

%runscript
    exec /opt/conda/bin/conda run --no-capture-output -n nucleosome "$@"

%environment
    export PYTHONPATH=/project:/opt/backend:${PYTHONPATH:-}
    export PATH=/opt/conda/envs/nucleosome/bin:/opt/conda/condabin:$PATH

%test
    /opt/conda/envs/nucleosome/bin/python -c "import numpy, polars, pandas, scipy, yaml"